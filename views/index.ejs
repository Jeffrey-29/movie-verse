<!DOCTYPE html>
<html lang="en">

<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Movieverse</title>

<link rel="stylesheet" href="/styles.css">

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">

<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&display=swap" rel="stylesheet">

</head>


<body>

<div class="container">

<h1>Movieverse</h1>


<!-- ================= SEARCH ================= -->

<div class="search-wrapper">

<form action="/search" method="get">

<input 
type="text" 
name="movie" 
placeholder="Search movie..."
autocomplete="off"
required
>

<button type="submit">Search</button>

</form>

<div id="suggestions" class="suggestions"></div>

</div>



<!-- ================= NOT FOUND ================= -->

<% if (typeof notFound !== "undefined" && notFound) { %>

<div class="not-found">
No movies found 😕
</div>

<% } %>



<!-- ================= SEARCH RESULTS ================= -->

<% if (movies) { %>

<h2>Search Results</h2>

<div class="movie-grid">

<% movies.forEach(movie => { %>

<a href="/movie/<%= movie.id %>" class="movie-link">

<div class="movie-card-small">

<div class="poster-wrapper">

<img 
src="<%= movie.isOMDB 
? movie.poster_path 
: (movie.poster_path 
? 'https://image.tmdb.org/t/p/w500' + movie.poster_path 
: 'https://via.placeholder.com/300x450?text=No+Image') %>"
>

<div class="movie-hover">

<% if(movie.vote_average){ %>
<p class="rating">
⭐ <%= movie.vote_average.toFixed(1) %>
</p>
<% } %>

<% if(movie.release_date){ %>
<p>📅 <%= movie.release_date %></p>
<% } %>

<% if(movie.overview){ %>
<p>
<%= movie.overview.substring(0,60) %>...
</p>
<% } %>

</div>

</div>

<h3><%= movie.title %></h3>

<p><%= movie.release_date || "" %></p>

</div>

</a>

<% }) %>

</div>

<% } %>



<!-- ================= TRENDING ================= -->

<% if (trending && trending.length > 0) { %>

<h2>Trending Movies</h2>

<div class="movie-row">

<% trending.forEach(movie => { %>

<a href="/movie/<%= movie.id %>" class="movie-link">

<div class="movie-card-small">

<div class="poster-wrapper">

<img 
src="<%= movie.poster_path 
? 'https://image.tmdb.org/t/p/w500' + movie.poster_path 
: 'https://via.placeholder.com/300x450?text=No+Image' %>"
>

<div class="movie-hover">

<p class="rating">
⭐ <%= movie.vote_average?.toFixed(1) %>
</p>

<p>📅 <%= movie.release_date %></p>

<p>
<%= movie.overview?.substring(0,60) %>...
</p>

</div>

</div>

<h3><%= movie.title %></h3>

<p><%= movie.release_date %></p>

</div>

</a>

<% }) %>

</div>

<% } %>



<!-- ================= LATEST ================= -->

<% if (latest && latest.length > 0) { %>

<h2>Latest Movies</h2>

<div class="movie-row">

<% latest.forEach(movie => { %>

<a href="/movie/<%= movie.id %>" class="movie-link">

<div class="movie-card-small">

<div class="poster-wrapper">

<img 
src="<%= movie.poster_path 
? 'https://image.tmdb.org/t/p/w500' + movie.poster_path 
: 'https://via.placeholder.com/300x450?text=No+Image' %>"
>

<div class="movie-hover">

<p class="rating">
⭐ <%= movie.vote_average?.toFixed(1) %>
</p>

<p>📅 <%= movie.release_date %></p>

<p>
<%= movie.overview?.substring(0,60) %>...
</p>

</div>

</div>

<h3><%= movie.title %></h3>

<p><%= movie.release_date %></p>

</div>

</a>

<% }) %>

</div>

<% } %>



<!-- ================= TOP RATED ================= -->

<% if (topRated && topRated.length > 0) { %>

<h2>Top Rated Movies</h2>

<div class="movie-row">

<% topRated.forEach(movie => { %>

<a href="/movie/<%= movie.id %>" class="movie-link">

<div class="movie-card-small">

<div class="poster-wrapper">

<img 
src="<%= movie.poster_path 
? 'https://image.tmdb.org/t/p/w500' + movie.poster_path 
: 'https://via.placeholder.com/300x450?text=No+Image' %>"
>

<div class="movie-hover">

<p class="rating">
⭐ <%= movie.vote_average?.toFixed(1) %>
</p>

<p>📅 <%= movie.release_date %></p>

<p>
<%= movie.overview?.substring(0,60) %>...
</p>

</div>

</div>

<h3><%= movie.title %></h3>

<p><%= movie.release_date %></p>

</div>

</a>

<% }) %>

</div>

<% } %>



<!-- ================= GENRES ================= -->

<% if (genres && genres.length > 0) { %>

<h2>Browse by Genre</h2>

<div class="genre-list">

<% genres.forEach(genre => { %>

<a href="/genre/<%= genre.id %>" class="genre-btn">
<%= genre.name %>
</a>

<% }) %>

</div>

<% } %>

</div>



<!-- ================= SEARCH SUGGESTIONS SCRIPT ================= -->

<script>

const input = document.querySelector("input[name='movie']");
const suggestions = document.getElementById("suggestions");

input.addEventListener("input", async () => {

const query = input.value;

if(query.length < 2){
suggestions.innerHTML = "";
suggestions.style.display = "none";
return;
}

const res = await fetch(`/suggest?q=${query}`);
const data = await res.json();

suggestions.innerHTML = data.map(movie => `
<div class="suggest-item" onclick="selectMovie('${movie.title}')">
${movie.title}
</div>
`).join("");

suggestions.style.display = "block";

});


function selectMovie(title){
input.value = title;
suggestions.innerHTML = "";
suggestions.style.display = "none";
}


/* CLOSE WHEN CLICK OUTSIDE */

document.addEventListener("click", function(e){

if(!e.target.closest(".search-wrapper")){
suggestions.style.display = "none";
}

});


</script>


</body>
</html>