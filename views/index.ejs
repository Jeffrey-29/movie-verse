: 'https://via.placeholder.com/300x450' %>"
>

<div class="movie-hover">
<p class="rating">⭐ <%= movie.vote_average?.toFixed(1) %></p>
<p>📅 <%= startYear %></p>
</div>

</div>

<h3><%= movie.title || movie.name %></h3>
<p><%= startYear %></p>

</div>

</a>

<% }) %>

</div>

<% } %>



<!-- ================= TOP RATED ================= -->

<% if (topRated && topRated.length > 0) { %>

<h2>Top Rated</h2>

<div class="movie-row">

<% topRated.forEach(movie => { 

const start = movie.release_date || movie.first_air_date;
const startYear = start ? start.substring(0,4) : "";

%>

<a href="/<%= movie.first_air_date ? 'tv' : 'movie' %>/<%= movie.id %>" class="movie-link">

<div class="movie-card-small">

<div class="poster-wrapper">

<button 
class="wishlist-btn"
data-id="<%= movie.id %>"
data-title="<%= movie.title || movie.name %>"
data-poster="https://image.tmdb.org/t/p/w500<%= movie.poster_path %>"
onclick="toggleWishlist(event,this)"
>
♡
</button>

<img 
src="<%= movie.poster_path 
? 'https://image.tmdb.org/t/p/w500' + movie.poster_path 
: 'https://via.placeholder.com/300x450' %>"
>

<div class="movie-hover">
<p class="rating">⭐ <%= movie.vote_average?.toFixed(1) %></p>
<p>📅 <%= startYear %></p>
</div>

</div>

<h3><%= movie.title || movie.name %></h3>
<p><%= startYear %></p>

</div>

</a>

<% }) %>

</div>

<% } %>

<!-- ================= YOU MAY ALSO LIKE ================= -->

<div id="recommendSection" style="display:none">
<h2 id="recommendTitle">You May Also Like</h2>
<div id="recommendRow" class="movie-row"></div>
</div>


<!-- ================= WATCHED ================= -->

<div id="watchedSection" style="display:none">
<h2>Watched</h2>
<div id="watchedRow" class="movie-row"></div>
</div>



</div>



<script>

document.addEventListener("DOMContentLoaded", function(){

/* ================= CONTINUE WATCHING ================= */

const recent = JSON.parse(localStorage.getItem("recentMovies"));

if(recent && recent.length > 0){

document.getElementById("continueSection").style.display = "block";

const row = document.getElementById("continueRow");

recent.forEach(movie => {

row.innerHTML += `
<div class="continue-wrapper">

<a href="/${movie.type || 'movie'}/${movie.id}" class="movie-link">

<div class="continue-card">

<img src="${movie.poster}">

${movie.progress > 0 ? `
<div class="progress-bar">
<div class="progress" style="width:${movie.progress}%"></div>
</div>
` : ""}

<h3>${movie.title}</h3>

</div>

</a>

<button class="remove-btn" data-id="${movie.id}">
✕
</button>

</div>
`;

});

document.querySelectorAll(".remove-btn").forEach(btn => {

btn.addEventListener("click", function(e){

e.stopPropagation();

const id = this.dataset.id;

removeMovie(id);

});

});

}


/* ================= WATCHED ================= */

const watched = JSON.parse(localStorage.getItem("watched"));

if(watched && watched.length > 0){

document.getElementById("watchedSection").style.display = "block";

const row = document.getElementById("watchedRow");

watched.forEach(movie => {

row.innerHTML += `
<a href="/${movie.type || 'movie'}/${movie.id}" class="movie-link">

<div class="continue-card">

<img src="${movie.poster}">

<h3>${movie.title}</h3>

</div>

</a>
`;

});

}


/* ================= YOU MAY ALSO LIKE ================= */

if(watched && watched.length > 0){

const lastWatched = watched[0];

document.getElementById("recommendTitle").innerText =
`Because you watched ${lastWatched.title}`;

fetch(`/recommend/${lastWatched.id}`)
.then(res => res.json())
.then(data => {

if(data && data.length > 0){

document.getElementById("recommendSection").style.display = "block";

const row = document.getElementById("recommendRow");

data.slice(0,10).forEach(movie => {

row.innerHTML += `
<a href="/${movie.first_air_date ? 'tv' : 'movie'}/${movie.id}" class="movie-link">

<div class="movie-card-small">

<img src="https://image.tmdb.org/t/p/w500${movie.poster_path}">

<h3>${movie.title || movie.name}</h3>

</div>

</a>
`;

});

}

});

}

updateWishlistUI();

});


function removeMovie(id){

let recent = JSON.parse(localStorage.getItem("recentMovies")) || [];

recent = recent.filter(movie => movie.id != id);

localStorage.setItem("recentMovies", JSON.stringify(recent));

location.reload();

}

</script>



<script>

function getWishlist(){
return JSON.parse(localStorage.getItem("wishlist")) || [];
}

function saveWishlist(list){
localStorage.setItem("wishlist", JSON.stringify(list));
}


function toggleWishlist(e,btn){

e.preventDefault();
e.stopPropagation();

const id = btn.dataset.id;
const title = btn.dataset.title;
const poster = btn.dataset.poster;

let wishlist = getWishlist();

const exists = wishlist.find(movie => movie.id == id);

if(exists){

wishlist = wishlist.filter(movie => movie.id != id);

}else{

wishlist.unshift({
id,
title,
poster
});

}

saveWishlist(wishlist);

updateWishlistUI();

}


function updateWishlistUI(){

const wishlist = getWishlist();

document.querySelectorAll(".wishlist-btn").forEach(btn=>{

const id = btn.dataset.id;

if(wishlist.find(movie => movie.id == id)){

btn.classList.add("active");
btn.innerHTML = "❤";

}else{

btn.classList.remove("active");
btn.innerHTML = "♡";

}

});

}


</script>
<% } %>
