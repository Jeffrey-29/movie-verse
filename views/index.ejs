<script>

function renderMovies(movies){

const grid = document.getElementById("filterGrid")

const fragment = document.createDocumentFragment()

movies.forEach(movie=>{

const year =
(movie.release_date || movie.first_air_date || "").substring(0,4)

const div = document.createElement("div")

div.innerHTML = `
<a href="/${movie.first_air_date ? 'tv' : 'movie'}/${movie.id}" class="movie-link">

<div class="movie-card-small">

<img src="https://image.tmdb.org/t/p/w500${movie.poster_path}">

<h3>${movie.title || movie.name}</h3>
<p>${year}</p>

</div>

</a>
`

fragment.appendChild(div)

})

grid.appendChild(fragment)

}
</script>
<script>

let page = 1
let loading = false

window.filterPage = window.filterPage || 1
window.filterLoading = false
window.filterUrl = window.filterUrl || ""

window.addEventListener("scroll", async ()=>{

/* ================= FILTER SCROLL ================= */

if(window.filterUrl){

if(window.filterLoading) return

if(window.innerHeight + window.scrollY >= document.body.offsetHeight - 500){

window.filterLoading = true
window.filterPage++

document.getElementById("filterLoading").style.display = "block"

const res = await fetch(`${window.filterUrl}&page=${window.filterPage}`)
const data = await res.json()

document.getElementById("filterLoading").style.display = "none"

if(!data.results || data.results.length === 0){
return
}

renderMovies(data.results)

window.filterLoading = false

}

return
}




if(loading) return

if(window.innerHeight + window.scrollY >= document.body.offsetHeight - 500){

loading = true
page++

const params = new URLSearchParams(window.location.search)
params.set("page",page)

const loadingDiv = document.getElementById("loading")

if(loadingDiv){
loadingDiv.style.display = "block"
}

const res = await fetch(`/filter?${params.toString()}`)
const data = await res.json()

if(loadingDiv){
loadingDiv.style.display = "none"
}

const grid = document.querySelector(".movie-grid")

if(!data.results || data.results.length === 0){
return
}

data.results.forEach(movie=>{

const year = (movie.release_date || movie.first_air_date || "").substring(0,4)

grid.innerHTML += `
<a href="/${movie.first_air_date ? 'tv' : 'movie'}/${movie.id}" class="movie-link">

<div class="movie-card-small">

<img src="https://image.tmdb.org/t/p/w500${movie.poster_path}">

<h3>${movie.title || movie.name}</h3>
<p>${year}</p>

</div>

</a>
`

})

loading = false

}

})

</script>
<script>

window.addEventListener("beforeunload", ()=>{
localStorage.setItem("scrollPos", window.scrollY)
})

window.addEventListener("load", ()=>{
const pos = localStorage.getItem("scrollPos")
if(pos){
window.scrollTo(0, pos)
}
})

</script>
<script>

window.addEventListener("pageshow", (event)=>{

if(event.persisted){

const pos = sessionStorage.getItem("scrollPos")
if(pos) window.scrollTo(0,pos)

}else{

window.scrollTo(0,0)

}

})

window.addEventListener("scroll",()=>{
sessionStorage.setItem("scrollPos", window.scrollY)
})

</script>


<script>

document.querySelectorAll(".sound-btn").forEach(btn=>{

btn.addEventListener("click",()=>{

const iframe = btn.parentElement.querySelector("iframe")

if(btn.innerText === "🔇"){
iframe.src = iframe.src.replace("mute=1","mute=0")
btn.innerText = "🔊"
}else{
iframe.src = iframe.src.replace("mute=0","mute=1")
btn.innerText = "🔇"
}

})

})

</script>

<script>
const observer = new IntersectionObserver((entries)=>{

entries.forEach(entry=>{

const card = entry.target
const iframe = card.querySelector("iframe")
const video = card.querySelector(".hero-video")

if(!iframe) return

if(entry.isIntersecting){

if(!iframe.src){
iframe.src = iframe.dataset.src
}

video.style.opacity = 1

}else{

video.style.opacity = 0

}

})

},{
threshold: 0.4,
rootMargin: "100px"
})

document.querySelectorAll(".hero-card").forEach(card=>{
observer.observe(card)
})
document.querySelectorAll(".hero-card").forEach((card,index)=>{

if(index < 5){
const iframe = card.querySelector("iframe")
if(iframe){
iframe.src = iframe.dataset.src
}
}

})
</script>
<script>

document.querySelectorAll(".hero-card").forEach(card=>{

card.addEventListener("click", ()=>{

const id = card.dataset.id
const type = card.dataset.type

window.location.href = `/${type}/${id}`

})

})

</script>




