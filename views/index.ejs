<body>

<%- include("partials/header") %>

<div class="container">

    <%
const title =
typeof genreName !== "undefined"
? genreName
: (typeof searchQuery !== "undefined" && searchQuery
? `Search Results for "${searchQuery}"`
: "Results");
%>



<!-- ================= GENRE RESULTS ================= -->

<% if(movies && movies.length > 0){ %>

<h2><%= title %></h2>
<div class="movie-grid">
    <div id="loading" class="loading">
Loading more movies...
</div>

<% movies.forEach(movie => { 
const start = movie.release_date || movie.first_air_date;
const startYear = start ? start.substring(0,4) : "";
%>

<a href="/<%= movie.first_air_date ? 'tv' : 'movie' %>/<%= movie.id %>" class="movie-link">

<div class="movie-card-small">

<img 
src="<%= movie.poster_path 
? 'https://image.tmdb.org/t/p/w500' + movie.poster_path 
: 'https://via.placeholder.com/300x450' %>"
>

<h3><%= movie.title || movie.name %></h3>
<p><%= startYear %></p>

</div>

</a>

<% }) %>

</div>

<% } else { %>
<% if(topPicks && topPicks.length > 0){ %>

<h2>Top Picks</h2>

<div class="top-picks">

<% topPicks.forEach(movie => { %>

<div 
class="hero-card"
data-id="<%= movie.id %>"
data-type="<%= movie.first_air_date ? 'tv' : 'movie' %>"
>

<img class="hero-image"
src="https://image.tmdb.org/t/p/original<%= movie.backdrop_path %>">

<% if(movie.trailer && movie.trailer !== "undefined"){ %>
<div class="hero-video">
<iframe
src=""
data-src="https://www.youtube-nocookie.com/embed/<%= movie.trailer %>?autoplay=1&mute=1&controls=0&modestbranding=1&rel=0&playsinline=1"
allow="autoplay; encrypted-media"
allowfullscreen
></iframe>
</div>

<button class="sound-btn">🔇</button>

<% } %>

<div class="hero-overlay">

<h2><%= movie.title || movie.name %></h2>

<p>
⭐ <%= movie.vote_average?.toFixed(1) %>
•
<%= (movie.release_date || movie.first_air_date || "").substring(0,4) %>
</p>

</div>

</div>

<% }) %>

</div>
<% } %>

<div id="filterResults" style="display:none">

<h2>Filtered Results</h2>

<div id="filterGrid" class="movie-grid"></div>

<div id="filterLoading" class="loading">
Loading more movies...
</div>

</div>


<!-- ================= LATEST ================= -->
<!-- ================= LATEST ================= -->

<% if (latest && latest.length > 0) { %>

<h2>Latest</h2>

<div class="movie-row">

<% latest.forEach(movie => { 
const start = movie.release_date || movie.first_air_date;
const startYear = start ? start.substring(0,4) : "";
%>

<a href="/<%= movie.first_air_date ? 'tv' : 'movie' %>/<%= movie.id %>" class="movie-link">

<div class="movie-card-small">

<div class="poster-wrapper">

<button 
class="wishlist-btn"
data-id="<%= movie.id %>"
data-title="<%= movie.title || movie.name %>"
data-poster="https://image.tmdb.org/t/p/w500<%= movie.poster_path %>"
onclick="toggleWishlist(event,this)"
>
♡
</button>

<img 
src="<%= movie.poster_path 
? 'https://image.tmdb.org/t/p/w500' + movie.poster_path 
: 'https://via.placeholder.com/300x450' %>"
>

<div class="movie-hover">
<p class="rating">⭐ <%= movie.vote_average?.toFixed(1) %></p>
<p>📅 <%= startYear %></p>
</div>

</div>

<h3><%= movie.title || movie.name %></h3>
<p><%= startYear %></p>

</div>

</a>

<% }) %>

</div>

<% } %>



