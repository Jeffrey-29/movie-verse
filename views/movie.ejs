<!DOCTYPE html>
<html>

<head>
<title><%= movie.title || movie.name %></title>
<link rel="stylesheet" href="/styles.css">
</head>

<body>

<%- include("partials/header") %>

<%
const stream = providers?.flatrate || [];
const rent = providers?.rent || [];
const buy = providers?.buy || [];

const title = movie.title || movie.name;

const justWatchLink =
`https://www.justwatch.com/in/search?q=${encodeURIComponent(title)}`;

const backdrop = movie.backdrop_path 
? "https://image.tmdb.org/t/p/original" + movie.backdrop_path
: "https://via.placeholder.com/1920x800?text=Movieverse";
%>


<!-- ================= HERO ================= -->

<div class="hero"
style="background-image:url('<%= backdrop %>')">

<div class="hero-overlay">

<div class="hero-content">

<div class="poster">
   <button 
class="wishlist-btn wishlist-btn-large"
data-id="<%= movie.id %>"
data-title="<%= movie.title || movie.name %>"
data-poster="https://image.tmdb.org/t/p/w500<%= movie.poster_path %>"
onclick="toggleWishlist(event,this)"
>
♡
</button>
<button 
class="watched-btn"
data-id="<%= movie.id %>"
data-title="<%= movie.title || movie.name %>"
data-poster="https://image.tmdb.org/t/p/w500<%= movie.poster_path %>"
onclick="toggleWatched(event,this)"
>
✓ Watched
</button>

<img 
src="<%= movie.poster_path 
? 'https://image.tmdb.org/t/p/w500' + movie.poster_path 
: 'https://via.placeholder.com/300x450' %>"
>

<% if(stream.length > 0) { %>

<a 
href="<%= justWatchLink %>"
target="_blank"
class="stream-badge">

<img src="https://image.tmdb.org/t/p/w200<%= stream[0].logo_path %>">

<span>Now Streaming</span>

</a>

<% } %>

</div>


<div class="hero-info">

<h1><%= movie.title || movie.name %></h1>

<div class="meta">

<span>⭐ <%= movie.vote_average?.toFixed(1) %></span>

<span>📅 <%= movie.release_date || movie.first_air_date %></span>

<% if(movie.runtime){ %>
<span>🎬 <%= movie.runtime %> min</span>
<% } %>

</div>

<p class="overview">
<%= movie.overview %>
</p>

</div>

</div>

</div>

</div>



<!-- ================= WATCH + TRAILER ================= -->

<div class="watch-trailer-container">

<div class="watch-left">

<h2>Where to Watch</h2>

<% if(stream.length > 0){ %>

<h3>Stream</h3>

<div class="watch-row">

<% stream.forEach(service => { %>

<a href="<%= justWatchLink %>" target="_blank" class="watch-logo">

<img
src="https://image.tmdb.org/t/p/w200<%= service.logo_path %>"
title="<%= service.provider_name %>">

</a>

<% }) %>

</div>

<% } %>



<% if(rent.length > 0){ %>

<h3>Rent</h3>

<div class="watch-row">

<% rent.forEach(service => { %>

<a href="<%= justWatchLink %>" target="_blank" class="watch-logo">

<img
src="https://image.tmdb.org/t/p/w200<%= service.logo_path %>"
title="<%= service.provider_name %>">

</a>

<% }) %>

</div>

<% } %>



<% if(buy.length > 0){ %>

<h3>Buy</h3>

<div class="watch-row">

<% buy.forEach(service => { %>

<a href="<%= justWatchLink %>" target="_blank" class="watch-logo">

<img
src="https://image.tmdb.org/t/p/w200<%= service.logo_path %>"
title="<%= service.provider_name %>">

</a>

<% }) %>

</div>

<% } %>


<% if(stream.length === 0 && rent.length === 0 && buy.length === 0){ %>

<p class="no-streaming">
Not available in your region
</p>

<% } %>

</div>



<div class="trailer-right">

<h2>Trailer</h2>

<% if(trailer){ %>

<div class="trailer-card">

<iframe
src="https://www.youtube.com/embed/<%= trailer.key %>"
frameborder="0"
allowfullscreen>
</iframe>

</div>

<% } else { %>

<div class="trailer-card">

<div class="no-trailer">
Trailer not available
</div>

</div>

<% } %>

</div>

</div>



<!-- ================= CAST ================= -->

<% if(cast && cast.length > 0){ %>

<div class="cast-section">

<h2>Cast</h2>

<div class="cast-row">

<% cast.forEach(actor => { %>

<a href="/actor/<%= actor.id %>" class="cast-link">

<div class="cast-card">

<img
src="<%= actor.profile_path 
? 'https://image.tmdb.org/t/p/w200' + actor.profile_path 
: 'https://via.placeholder.com/200x300' %>">

<div class="cast-info">

<p><%= actor.name %></p>

<span><%= actor.character %></span>

</div>

</div>

</a>

<% }) %>

</div>

</div>

<% } %>



<!-- ================= SIMILAR ================= -->

<% if(similar && similar.length > 0){ %>

<div class="similar-section">

<h2>More Like This</h2>

<div class="movie-row">

<% similar.forEach(movie => { %>

<a href="/<%= movie.first_air_date ? 'tv' : 'movie' %>/<%= movie.id %>" class="movie-link">

<div class="similar-card">

<img 
src="<%= movie.poster_path 
? 'https://image.tmdb.org/t/p/w500' + movie.poster_path 
: 'https://via.placeholder.com/300x450' %>">

<h3><%= movie.title || movie.name %></h3>

</div>

</a>

<% }) %>

</div>

</div>

<% } %>



<div class="container">

<button onclick="history.back()" class="back-btn">
⬅ Back
</button>

</div>



<!-- ================= CONTINUE WATCHING SAVE ================= -->

<script>

const movieData = {
id: "<%= movie.id %>",
title: "<%= movie.title || movie.name %>",
poster: "<%= movie.poster_path 
? 'https://image.tmdb.org/t/p/w500' + movie.poster_path 
: '' %>",
type: "<%= movie.first_air_date ? 'tv' : 'movie' %>",
progress:0
};

let watched = JSON.parse(localStorage.getItem("watched")) || [];

/* don't add to continue watching if watched */

if(!watched.find(movie => movie.id === movieData.id)){

let recent = JSON.parse(localStorage.getItem("recentMovies")) || [];

recent = recent.filter(m => m.id !== movieData.id);

recent.unshift(movieData);

recent = recent.slice(0,10);

localStorage.setItem("recentMovies", JSON.stringify(recent));

}

</script>
<script>

function getWishlist(){
return JSON.parse(localStorage.getItem("wishlist")) || [];
}

function saveWishlist(list){
localStorage.setItem("wishlist", JSON.stringify(list));
}

function toggleWishlist(e,id,title,poster){

e.preventDefault();

let wishlist = getWishlist();

const exists = wishlist.find(movie => movie.id == id);

const btn = e.target;

if(exists){

wishlist = wishlist.filter(movie => movie.id != id);
btn.classList.remove("active");
btn.innerHTML = "♡";

}else{

wishlist.unshift({
id,
title,
poster
});

btn.classList.add("active");
btn.innerHTML = "❤";

}

saveWishlist(wishlist);

}


/* Sync heart on page load */

document.addEventListener("DOMContentLoaded", ()=>{

const wishlist = getWishlist();

document.querySelectorAll(".wishlist-btn").forEach(btn=>{

const id = btn.dataset.id;

if(wishlist.find(movie => movie.id == id)){
btn.classList.add("active");
btn.innerHTML = "❤";
}

});

});

</script>
<script>

function getWishlist(){
return JSON.parse(localStorage.getItem("wishlist")) || [];
}

function saveWishlist(list){
localStorage.setItem("wishlist", JSON.stringify(list));
}


function toggleWishlist(e,btn){

e.preventDefault();

const id = btn.dataset.id;
const title = btn.dataset.title;
const poster = btn.dataset.poster;

let wishlist = getWishlist();

const exists = wishlist.find(movie => movie.id == id);

if(exists){

wishlist = wishlist.filter(movie => movie.id != id);
btn.classList.remove("active");
btn.innerHTML = "♡";

}else{

wishlist.unshift({
id,
title,
poster
});

btn.classList.add("active");
btn.innerHTML = "❤";

}

saveWishlist(wishlist);

}


/* Load state */

document.addEventListener("DOMContentLoaded", ()=>{

const wishlist = getWishlist();

document.querySelectorAll(".wishlist-btn").forEach(btn=>{

const id = btn.dataset.id;

if(wishlist.find(movie => movie.id == id)){
btn.classList.add("active");
btn.innerHTML = "❤";
}

});

});

</script>
<script>

function getWatched(){
return JSON.parse(localStorage.getItem("watched")) || [];
}

function saveWatched(list){
localStorage.setItem("watched", JSON.stringify(list));
}

function toggleWatched(e,btn){

e.stopPropagation();

const id = btn.dataset.id;
const title = btn.dataset.title;
const poster = btn.dataset.poster;

let watched = getWatched();

const exists = watched.find(movie => movie.id == id);

if(exists){

watched = watched.filter(movie => movie.id != id);

btn.classList.remove("active");
btn.innerHTML = "✓ Watched";

}else{

watched.unshift({
id,
title,
poster
});

btn.classList.add("active");
btn.innerHTML = "✓ Watched";

}

/* remove from continue watching */

let recent = JSON.parse(localStorage.getItem("recentMovies")) || [];

recent = recent.filter(movie => movie.id != id);

localStorage.setItem("recentMovies", JSON.stringify(recent));

saveWatched(watched);

/* refresh homepage sections */

setTimeout(()=>{
location.reload();
},200);

}


document.addEventListener("DOMContentLoaded",()=>{

const watched = getWatched();

document.querySelectorAll(".watched-btn").forEach(btn=>{

const id = btn.dataset.id;

if(watched.find(movie => movie.id == id)){
btn.classList.add("active");
}

});

});

</script>
</body>

</html>