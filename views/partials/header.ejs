<header class="navbar">

<div class="nav-left">

<button class="menu-btn" onclick="toggleGenre()">
☰
</button>

</div>


<div class="nav-center">
<a href="/" class="logo">
🎬 Movieverse
</a>
</div>


<div class="nav-right">

<button onclick="toggleFilters()" class="filter-btn-header">
filters
</button>

<a href="/wishlist" class="wishlist-link">
❤ Wishlist
</a>

<form action="/search" method="get" class="nav-search">

<input 
type="text"
name="movie"
id="searchInput"
placeholder="Search movies..."
autocomplete="off"
>

<div id="suggestions" class="suggestions"></div>

</form>

